# Aivory AI Readiness Platform - Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# OPENROUTER AI CONFIGURATION (REQUIRED FOR PAID TIERS)
# ============================================
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# ZENCLAW AI CONFIGURATION (FALLBACK)
# ============================================
ZENCLAW_API_KEY=your-zenclaw-api-key-here
ZENCLAW_BASE_URL=https://api.zenclaw.ai/v1

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-secret-key-here-change-in-production
SUPERADMIN_PASSWORD=your-superadmin-password-here

# ============================================
# SERVER CONFIGURATION (OPTIONAL)
# ============================================
# HOST=0.0.0.0
# PORT=8081

# ============================================
# OLLAMA CONFIGURATION (LEGACY - OPTIONAL)
# ============================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistralai/Mistral-7B-Instruct
# LLM_TIMEOUT=5.0
# LLM_MAX_TOKENS=500
# LLM_TEMPERATURE=0.7

# ============================================
# NOTES
# ============================================
# - OpenRouter is the primary AI provider with fallback to Zenclaw
# - Free diagnostic tier works without AI configuration
# - Paid tiers (Snapshot, Blueprint) require OpenRouter or Zenclaw API key
# - JWT_SECRET should be a long random string in production
# - SUPERADMIN_PASSWORD is for the GrandMasterRCH account

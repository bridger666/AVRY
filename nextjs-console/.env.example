# VPS Bridge Configuration
# These variables are required for connecting to the VPS bridge gateway

# VPS Bridge URL (production server)
VPS_BRIDGE_URL=http://43.156.108.96:3001

# VPS Bridge API Key (for authentication)
VPS_BRIDGE_API_KEY=your_api_key_here

# n8n Configuration
# Base URL for the n8n editor (used for "View in n8n" button)
NEXT_PUBLIC_N8N_EDITOR_BASE_URL=http://localhost:5678
